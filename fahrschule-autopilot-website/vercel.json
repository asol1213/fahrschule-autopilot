{
  "crons": [
    {
      "path": "/api/cron/monthly-report",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/mahnwesen",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/dsgvo-cleanup",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/blog/cron",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/anomaly-check",
      "schedule": "0 7 * * 1-5"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https://*.supabase.co https://*.supabase.io wss://*.supabase.co https://retellai.com https://api.anthropic.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
