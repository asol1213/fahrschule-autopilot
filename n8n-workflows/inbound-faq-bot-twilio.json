    {
      "parameters": {
        "jsCode": "// =====================================================\n// ZENTRALER INBOUND-ROUTER\n// Klassifiziert jede eingehende WhatsApp-Nachricht\n// und leitet sie an den richtigen Sub-Flow weiter.\n// =====================================================\nconst body = $input.first().json.body || $input.first().json;\nconst messageBody = (body.Body || body.body || body.message || '').trim();\nconst from = (body.From || body.from || '').replace('whatsapp:', '').trim();\nconst mediaUrl = body.MediaUrl0 || body.mediaUrl || '';\nconst mediaType = body.MediaContentType0 || body.mediaType || '';\n\nconst upper = messageBody.toUpperCase().trim();\nconst lower = messageBody.toLowerCase().trim();\n\n// --- 0. DSGVO OPT-OUT (STOP) ---\nconst stopKeywords = ['STOP', 'STOPP', 'ABMELDEN', 'OPT-OUT', 'OPTOUT', 'KEINE NACHRICHTEN', 'ABBESTELLEN', 'UNSUBSCRIBE'];\nif (stopKeywords.some(kw => upper === kw || upper === kw + ' BITTE')) {\n  return [{ json: { kategorie: 'opt_out', from, messageBody, mediaUrl, mediaType } }];\n}\n\n// --- 1. ABSAGE ---\nif (upper === 'ABSAGE' || upper === 'CANCEL' || upper === 'STORNIEREN' || upper === 'NEIN ABSAGE') {\n  return [{ json: { kategorie: 'absage', from, messageBody, mediaUrl, mediaType } }];\n}\n\n// --- 2. TERMINVERSCHIEBUNG (NEU) ---\nconst verschiebungKeywords = [\n  'verschieben', 'verschiebung', 'umbuchen', 'umbuchung',\n  'anderen termin', 'anderen tag', 'andere uhrzeit', 'andere zeit',\n  'neuer termin', 'neues datum', 'klappt leider nicht', 'kann leider nicht',\n  'passt nicht', 'nicht moeglich', 'verhindert'\n];\nconst isVerschiebung = verschiebungKeywords.some(kw => lower.includes(kw))\n  || upper.startsWith('VERSCHIEBEN')\n  || upper.startsWith('UMBUCHEN');\nif (isVerschiebung) {\n  return [{ json: { kategorie: 'verschiebung', from, messageBody, mediaUrl, mediaType } }];\n}\n\n// --- 3. BEWERTUNG (1-5 Sterne) ---\nconst bewertung = parseInt(messageBody);\nif (bewertung >= 1 && bewertung <= 5 && messageBody.trim().length === 1) {\n  return [{ json: { kategorie: 'bewertung', from, messageBody, bewertung, mediaUrl, mediaType } }];\n}\n\n// --- 4. BUCHUNGSBESTAETIGUNG ---\nif (upper === 'JA' || upper === 'OK' || upper === 'BESTAETIGEN' || upper === 'BESTÄTIGEN' || upper === 'YES') {\n  return [{ json: { kategorie: 'bestaetigung', from, messageBody, mediaUrl, mediaType } }];\n}\n\n// --- 5. DOKUMENT (Medien) ---\nif (mediaUrl || (mediaType && (\n  mediaType.includes('image') ||\n  mediaType.includes('pdf') ||\n  mediaType.includes('document') ||\n  mediaType.includes('application')\n))) {\n  return [{ json: { kategorie: 'dokument', from, messageBody, mediaUrl, mediaType } }];\n}\n\n// --- 6. BESCHWERDE ---\nconst beschwerdeKeywords = [\n  'beschwerde', 'unzufrieden', 'aerger', 'ärger', 'reklamation',\n  'wuetend', 'wütend', 'enttaeuscht', 'enttäuscht',\n  'katastrophe', 'frechheit', 'anwalt', 'rechtsanwalt',\n  'skandal', 'unmoeglich', 'unmöglich', 'zumutung', 'schande'\n];\nif (beschwerdeKeywords.some(kw => lower.includes(kw))) {\n  return [{ json: { kategorie: 'beschwerde', from, messageBody, mediaUrl, mediaType } }];\n}\n\n// --- 7. ALLES ANDERE → FAQ-BOT ---\nreturn [{ json: { kategorie: 'faq', from, messageBody, mediaUrl, mediaType } }];"
      },
      "id": "classify-message",
      "name": "Nachricht klassifizieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 300]
    },
