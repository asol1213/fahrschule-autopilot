        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-opus-4-5\",\n  \"max_tokens\": 600,\n  \"system\": \"Du bist der freundliche WhatsApp-Assistent der Fahrschule {{ $env.FAHRSCHUL_NAME }}. Antworte auf Deutsch, kurz und praegnant (max 3-4 Saetze). Nutze Emojis nur sehr sparsam.\\n\\nWichtige Infos ueber uns:\\n- Name: {{ $env.FAHRSCHUL_NAME }}\\n- Adresse: {{ $env.FAHRSCHUL_ADRESSE || 'Bitte im Buero erfragen' }}\\n- Telefon: {{ $env.FAHRSCHUL_TELEFON || 'Bitte im Buero erfragen' }}\\n- Oeffnungszeiten: {{ $env.OEFFNUNGSZEITEN || 'Mo-Fr 9-18 Uhr, Sa 9-13 Uhr' }}\\n- Fuehrerschein Klasse B: {{ $env.KOSTEN_KLASSE_B || 'ca. 2.500-3.500 EUR (abhaengig von benotigten Stunden)' }}\\n- Theorie-Unterricht: {{ $env.THEORIE_ZEITEN || '2x woechentlich abends' }}\\n- Theorie-Pruefung: 30 Fragen, maximal 10 Fehlerpunkte erlaubt\\n- Benoetigte Unterlagen: Sehtest (max. 2 Jahre alt), Erste-Hilfe-Kurs, biometrisches Passfoto, Personalausweis\\n- Online Theorie-Trainer: {{ $env.WEBSITE_URL }}/theorie\\n- Website: {{ $env.WEBSITE_URL }}\\n\\nRegeln:\\n- Bei Fragen zu Terminen oder Buchungen: Bitte im Buero anrufen oder auf der Website buchen.\\n- Wenn du etwas nicht sicher weisst: Sage das ehrlich und verweise aufs Buero.\\n- Erfinde NIEMALS Informationen.\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"{{ $json.messageBody.replace(/\\\"/g, '\\\\\\\"').replace(/\\n/g, ' ') }}\"\n    }\n  ]\n}"
      },
      "id": "claude-faq",
      "name": "Claude AI Antwort generieren",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [920, 100],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Claude-Antwort extrahieren + Fallback bei Fehler\nconst response = $input.first().json;\nconst from = $('Nachricht klassifizieren').first().json.from;\nconst originalMessage = $('Nachricht klassifizieren').first().json.messageBody;\nlet antwort = '';\n\ntry {\n  if (response.content && response.content[0] && response.content[0].text) {\n    antwort = response.content[0].text.trim();\n  } else if (response.error) {\n    // API-Fehler\n    antwort = 'Entschuldigung, ich kann Ihre Frage gerade nicht beantworten. Bitte rufen Sie uns an oder schreiben Sie uns eine E-Mail.';\n  }\n} catch(e) {\n  antwort = 'Entschuldigung, ich konnte Ihre Frage gerade nicht verarbeiten. Bitte versuchen Sie es spaeter erneut.';\n}\n\nif (!antwort) {\n  antwort = 'Vielen Dank fuer Ihre Nachricht! Fuer eine genaue Antwort wenden Sie sich bitte direkt an uns: ' + ($env.FAHRSCHUL_TELEFON || 'Buero');\n}\n\n// WhatsApp-Limit: 4.096 Zeichen\nif (antwort.length > 1500) {\n  antwort = antwort.substring(0, 1497) + '...';\n}\n\nreturn [{ json: { antwort, from, originalMessage } }];"
      },
      "id": "parse-claude",
      "name": "AI-Antwort aufbereiten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1140, 100]
    },
