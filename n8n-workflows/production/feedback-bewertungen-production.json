{
  "name": "Fahrschule Autopilot - Feedback & Google-Bewertungen (Production)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "feedback-trigger",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Trigger - Schueler hat bestanden",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        220,
        300
      ],
      "webhookId": "feedback-trigger"
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 1
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Stuendlich pruefen",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        220,
        500
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/schueler?tenant_id=eq.{{ $env.TENANT_ID }}&feedback_status=not.in.(gefragt,erhalten,google)&select=id,vorname,nachname,telefon,wa_opt_out,feedback_status,pruefung_bestanden_am,letzte_fahrstunde,anzahl_stunden",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "fullResponse": false
            }
          }
        }
      },
      "id": "load-schueler",
      "name": "Schueler laden (Production)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "// Schueler filtern die Feedback bekommen sollen\nconst items = $input.all();\nconst now = new Date();\nconst results = [];\n\nfor (const item of items) {\n  const data = item.json;\n  if (data.wa_opt_out) continue;\n\n  const name = `${data.vorname} ${data.nachname}`;\n  const telefon = data.telefon || '';\n  const pruefungDatum = data.pruefung_bestanden_am || '';\n  const letzteFahrstunde = data.letzte_fahrstunde || '';\n  const anzahlStunden = parseInt(data.anzahl_stunden || '0');\n\n  if (!telefon || !name) continue;\n\n  let sollFeedbackBekommen = false;\n  let trigger = '';\n\n  // Pruefung bestanden?\n  if (pruefungDatum) {\n    const pruefung = new Date(pruefungDatum);\n    const stundenSeit = (now.getTime() - pruefung.getTime()) / (1000 * 60 * 60);\n    if (stundenSeit >= 2 && stundenSeit <= 48) {\n      sollFeedbackBekommen = true;\n      trigger = 'pruefung_bestanden';\n    }\n  }\n\n  // Letzte Fahrstunde (alle 10 Stunden Meilenstein)\n  if (!sollFeedbackBekommen && letzteFahrstunde && anzahlStunden > 0 && anzahlStunden % 10 === 0) {\n    const letzteStunde = new Date(letzteFahrstunde);\n    const stundenSeit = (now.getTime() - letzteStunde.getTime()) / (1000 * 60 * 60);\n    if (stundenSeit >= 2 && stundenSeit <= 48) {\n      sollFeedbackBekommen = true;\n      trigger = 'meilenstein_' + anzahlStunden;\n    }\n  }\n\n  if (sollFeedbackBekommen) {\n    results.push({\n      json: {\n        schuelerName: name,\n        schuelerTelefon: telefon,\n        schuelerId: data.id,\n        trigger\n      }\n    });\n  }\n}\n\nreturn results.length > 0 ? results : [{ json: { skip: true } }];"
      },
      "id": "filter-schueler",
      "name": "Feedback-Kandidaten filtern",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        400
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "filter-skip",
              "leftValue": "={{ $json.skip }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notTrue"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "filter-valid",
      "name": "Nur gueltige Kandidaten",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [
        880,
        400
      ]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "from": "={{ $env.TWILIO_WHATSAPP_FROM }}",
        "to": "=whatsapp:{{ $json.schuelerTelefon }}",
        "body": "=Hallo {{ $json.schuelerName }}! 🎉\n\nWir hoffen, Sie sind zufrieden mit Ihrer Fahrschule!\n\nKurze Frage: Wie bewerten Sie uns auf einer Skala von 1-5?\n\n⭐ Antworten Sie einfach mit einer Zahl:\n5 = Hervorragend\n4 = Gut\n3 = Okay\n2 = Nicht so gut\n1 = Schlecht\n\nIhr Feedback hilft uns, noch besser zu werden! 🙏"
      },
      "id": "send-feedback-request",
      "name": "Feedback anfragen per WhatsApp",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [
        1100,
        400
      ],
      "credentials": {
        "twilioApi": {
          "id": "TWILIO_CREDENTIALS",
          "name": "Twilio"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/automation_log",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"tenant_id\": \"{{ $env.TENANT_ID }}\",\n  \"schueler_id\": \"{{ $json.schuelerId }}\",\n  \"telefon\": \"{{ $json.schuelerTelefon }}\",\n  \"typ\": \"feedback_gefragt\",\n  \"kanal\": \"whatsapp\",\n  \"status\": \"gesendet\",\n  \"details\": { \"trigger\": \"{{ $json.trigger }}\" }\n}",
        "options": {}
      },
      "id": "log-feedback-request",
      "name": "Feedback-Anfrage loggen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1320,
        400
      ]
    },
