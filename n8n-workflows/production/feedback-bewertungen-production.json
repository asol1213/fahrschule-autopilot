        "method": "PATCH",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/schueler?id=eq.{{ $json.schuelerId }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}"
