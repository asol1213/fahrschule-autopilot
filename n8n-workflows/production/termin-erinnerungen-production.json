      "name": "Eingehende WhatsApp Antwort",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        220,
        700
      ],
      "webhookId": "whatsapp-incoming"
    },
    {
      "parameters": {
        "jsCode": "// Eingehende Nachricht verarbeiten\nconst body = $input.first().json.body || $input.first().json;\nconst messageBody = (body.Body || body.body || '').trim().toUpperCase();\nconst from = body.From || body.from || '';\n\n// Nummer extrahieren\nconst telefon = from.replace('whatsapp:', '').trim();\n\nif (messageBody === 'ABSAGE' || messageBody === 'CANCEL' || messageBody === 'STORNIEREN') {\n  return [{\n    json: {\n      action: 'absage',\n      telefon,\n      message: messageBody,\n      timestamp: new Date().toISOString()\n    }\n  }];\n}\n\nif (messageBody === 'OK' || messageBody === 'JA' || messageBody === 'BESTÄTIGT') {\n  return [{\n    json: {\n      action: 'bestaetigung',\n      telefon,\n      message: messageBody,\n      timestamp: new Date().toISOString()\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    action: 'unbekannt',\n    telefon,\n    message: messageBody,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "id": "parse-response",
      "name": "Antwort auswerten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        700
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
