    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "from": "={{ $env.TWILIO_WHATSAPP_FROM }}",
        "to": "=whatsapp:{{ $json.schuelerTelefon }}",
        "body": "=Hallo {{ $json.schuelerName }}! 👋\n\nKurze Erinnerung an morgen:\n\n📅 {{ $json.terminDatumFormatiert }}\n🕐 {{ $json.terminZeitFormatiert }} Uhr\n🚗 {{ $json.terminArt }}\n👤 {{ $json.fahrlehrerName }}\n\nBitte denken Sie an:\n✅ Personalausweis\n✅ Festes Schuhwerk\n✅ Brille (falls noetig)\n\nKoennen Sie den Termin nicht wahrnehmen?\nAntworten Sie bitte mit ABSAGE.\n\nWir freuen uns auf Sie! 🚗"
      },
      "id": "twilio-24h",
      "name": "WhatsApp 24h Erinnerung",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [
        1360,
