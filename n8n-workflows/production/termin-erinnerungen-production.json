{
  "name": "Fahrschule Autopilot - Termin-Erinnerungen (Production)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 15
            }
          ]
        }
      },
      "id": "trigger-1",
      "name": "Alle 15 Min pruefen",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        220,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/fahrstunden?tenant_id=eq.{{ $env.TENANT_ID }}&status=eq.geplant&datum=gte.{{ $now.toISODate() }}&select=*,schueler:schueler_id(id,vorname,nachname,telefon,wa_opt_out),fahrlehrer:fahrlehrer_id(vorname,nachname)",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "fullResponse": false
            }
          }
        }
      },
      "id": "load-fahrstunden",
      "name": "Fahrstunden laden (Production)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        200
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/automation_log?typ=in.(erinnerung_24h,erinnerung_2h)&tenant_id=eq.{{ $env.TENANT_ID }}&select=telefon,datum,uhrzeit,typ,created_at",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}"
            }
          ]
        },
        "options": {}
      },
      "id": "load-log",
      "name": "Bereits gesendete Erinnerungen laden",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        420
      ]
    },
    {
      "parameters": {
        "jsCode": "// Fahrstunden verarbeiten und mit automation_log abgleichen\nconst fahrstunden = $('Fahrstunden laden (Production)').all();\nconst logItems = $('Bereits gesendete Erinnerungen laden').all();\n\n// Set von bereits gesendeten Erinnerungen\nconst gesendet = new Set();\nfor (const item of logItems) {\n  const d = item.json;\n  const key = `${d.telefon}_${d.datum}_${d.uhrzeit}_${d.typ}`;\n  gesendet.add(key);\n}\n\nconst now = new Date();\nconst results = [];\n\nfor (const item of fahrstunden) {\n  const data = item.json;\n  const schueler = data.schueler;\n  const fahrlehrer = data.fahrlehrer;\n\n  // Schueler-Daten pruefen\n  if (!schueler || !schueler.telefon || !schueler.vorname) continue;\n\n  // WhatsApp Opt-Out pruefen\n  if (schueler.wa_opt_out) continue;\n\n  const datum = data.datum;\n  const zeit = data.uhrzeit || data.zeit || '09:00';\n  const name = `${schueler.vorname} ${schueler.nachname}`;\n  const fahrlehrerName = fahrlehrer ? `${fahrlehrer.vorname} ${fahrlehrer.nachname}` : '';\n  const art = data.art || data.typ || 'Fahrstunde';\n\n  // Telefonnummer bereinigen\n  let telefon = schueler.telefon.toString().replace(/[\\s\\-\\/\\(\\)]/g, '');\n  if (!telefon.startsWith('+')) {\n    telefon = '+49' + telefon.replace(/^0/, '');\n  }\n\n  if (!datum) continue;\n\n  // Termin-Zeitpunkt berechnen\n  let terminDatum;\n  try {\n    if (datum.includes('.')) {\n      const parts = datum.split('.');\n      terminDatum = new Date(`${parts[2]}-${parts[1].padStart(2,'0')}-${parts[0].padStart(2,'0')}T${zeit}:00`);\n    } else {\n      terminDatum = new Date(`${datum}T${zeit}:00`);\n    }\n  } catch(e) {\n    continue;\n  }\n\n  if (isNaN(terminDatum.getTime())) continue;\n\n  // Stunden bis zum Termin\n  const stundenBis = (terminDatum.getTime() - now.getTime()) / (1000 * 60 * 60);\n\n  // 24h Erinnerung (23-25h vorher)\n  if (stundenBis >= 23 && stundenBis <= 25) {\n    const key = `${telefon}_${datum}_${zeit}_erinnerung_24h`;\n    if (!gesendet.has(key)) {\n      const optionen = { weekday: 'long', day: 'numeric', month: 'long' };\n      results.push({\n        json: {\n          schuelerName: name,\n          schuelerTelefon: telefon,\n          schuelerId: schueler.id,\n          fahrstundeId: data.id,\n          fahrlehrerName: fahrlehrerName,\n          terminArt: art,\n          terminDatum: datum,\n          terminZeit: zeit,\n          terminDatumFormatiert: terminDatum.toLocaleDateString('de-DE', optionen),\n          terminZeitFormatiert: zeit,\n          erinnerungsTyp: '24h',\n          logTyp: 'erinnerung_24h',\n          stundenBisTermin: Math.round(stundenBis * 10) / 10\n        }\n      });\n    }\n  }\n\n  // 2h Erinnerung (1.5-2.5h vorher)\n  if (stundenBis >= 1.5 && stundenBis <= 2.5) {\n    const key = `${telefon}_${datum}_${zeit}_erinnerung_2h`;\n    if (!gesendet.has(key)) {\n      results.push({\n        json: {\n          schuelerName: name,\n          schuelerTelefon: telefon,\n          schuelerId: schueler.id,\n          fahrstundeId: data.id,\n          fahrlehrerName: fahrlehrerName,\n          terminArt: art,\n          terminDatum: datum,\n          terminZeit: zeit,\n          terminDatumFormatiert: terminDatum.toLocaleDateString('de-DE', { weekday: 'long', day: 'numeric', month: 'long' }),\n          terminZeitFormatiert: zeit,\n          erinnerungsTyp: '2h',\n          logTyp: 'erinnerung_2h',\n          stundenBisTermin: Math.round(stundenBis * 10) / 10\n        }\n      });\n    }\n  }\n}\n\nreturn results.length > 0 ? results : [{ json: { skip: true } }];"
      },
      "id": "process-1",
      "name": "Termine verarbeiten + Duplikate filtern",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "filter-skip",
              "leftValue": "={{ $json.skip }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notTrue"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "filter-1",
      "name": "Nur gueltige Erinnerungen",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [
        920,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "check-24h",
              "leftValue": "={{ $json.erinnerungsTyp }}",
              "rightValue": "24h",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "switch-type",
      "name": "24h oder 2h",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        1140,
        300
