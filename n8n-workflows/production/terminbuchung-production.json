      "id": "webhook-lehrer",
      "name": "Fahrlehrer antwortet",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [220, 900],
      "webhookId": "lehrer-antwort"
    },
    {
      "parameters": {
        "jsCode": "// Fahrlehrer-Antwort auswerten\nconst body = $input.first().json.body || $input.first().json;\nconst messageBody = (body.Body || body.body || '').trim().toUpperCase();\nconst from = (body.From || body.from || '').replace('whatsapp:', '').trim();\n\n// BESTAETIGEN BK-XXXXX\nif (messageBody.startsWith('BESTAETIGEN') || messageBody.startsWith('BESTÄTIGEN')) {\n  const buchungsId = messageBody.split(' ')[1] || '';\n  return [{\n    json: {\n      action: 'bestaetigt',\n      buchungsId,\n      lehrerTelefon: from,\n      alternativDatum: '',\n      alternativZeit: ''\n    }\n  }];\n}\n\n// ALTERNATIV BK-XXXXX 29.03.2026 14:00\nif (messageBody.startsWith('ALTERNATIV')) {\n  const parts = messageBody.split(' ');\n  const buchungsId = parts[1] || '';\n  const altDatum = parts[2] || '';\n  const altZeit = parts[3] || '';\n  return [{\n    json: {\n      action: 'alternativ',\n      buchungsId,\n      lehrerTelefon: from,\n      alternativDatum: altDatum,\n      alternativZeit: altZeit\n    }\n  }];\n}\n\n// ABLEHNEN BK-XXXXX\nif (messageBody.startsWith('ABLEHNEN')) {\n  const buchungsId = messageBody.split(' ')[1] || '';\n  return [{\n    json: {\n      action: 'abgelehnt',\n      buchungsId,\n      lehrerTelefon: from,\n      alternativDatum: '',\n      alternativZeit: ''\n    }\n  }];\n}\n\nreturn [{ json: { action: 'unbekannt', lehrerTelefon: from, message: messageBody } }];"
      },
