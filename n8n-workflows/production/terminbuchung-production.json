      "id": "lookup-buchung",
      "name": "Buchung nachschlagen (Supabase)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [920, 800]
    },
    {
      "parameters": {
        "jsCode": "// Buchungs-Daten fuer Nachricht aufbereiten + Aktion weiterleiten\nconst buchungArr = $('Buchung nachschlagen (Supabase)').all();\nconst lehrerAntwort = $('Lehrer-Antwort auswerten').first().json;\n\nif (!buchungArr || buchungArr.length === 0) {\n  return [{ json: { error: 'Buchung nicht gefunden', action: lehrerAntwort.action } }];\n}\n\nconst b = buchungArr[0].json;\n\nreturn [{\n  json: {\n    buchungsId: b.buchungs_id,\n    schuelerName: `${b.vorname} ${b.nachname}`,\n    telefon: b.telefon,\n    terminArt: b.termin_art,\n    wunschDatum: b.wunsch_datum,\n    wunschZeit: b.wunsch_zeit,\n    fuehrerscheinKlasse: b.fuehrerschein_klasse,\n    action: lehrerAntwort.action,\n    alternativDatum: lehrerAntwort.alternativDatum,\n    alternativZeit: lehrerAntwort.alternativZeit,\n    lehrerTelefon: lehrerAntwort.lehrerTelefon\n  }\n}];"
      },
