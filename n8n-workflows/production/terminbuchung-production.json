      "id": "load-fahrlehrer",
      "name": "Fahrlehrer laden (Supabase)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [920, 580]
    },
    {
      "parameters": {
        "jsCode": "// Zustaendigen Fahrlehrer bestimmen + DSGVO wa_opt_out pruefen\nconst buchung = $('Buchung in Supabase speichern').first().json;\nconst fahrlehrerListe = $('Fahrlehrer laden (Supabase)').all();\n\nif (!buchung) throw new Error('Keine Buchungsdaten empfangen');\n\nconst wunschLehrer = (buchung.fahrlehrer_wunsch || '').toLowerCase();\n\n// DSGVO: Schueler wa_opt_out aus Supabase laden\nlet schuelerOptOut = false;\ntry {\n  const supabaseUrl = $env.SUPABASE_URL;\n  const serviceKey = $env.SUPABASE_SERVICE_KEY;\n  const tenantId = $env.TENANT_ID;\n  const tel = buchung.telefon;\n  if (tel && supabaseUrl && serviceKey) {\n    const resp = await fetch(\n      `${supabaseUrl}/rest/v1/schueler?telefon=eq.${encodeURIComponent(tel)}&tenant_id=eq.${tenantId}&select=wa_opt_out`,\n      { headers: { 'apikey': serviceKey, 'Authorization': `Bearer ${serviceKey}` } }\n    );\n    const data = await resp.json();\n    if (Array.isArray(data) && data.length > 0 && data[0].wa_opt_out === true) {\n      schuelerOptOut = true;\n    }\n  }\n} catch(e) { /* Fehler beim Opt-Out Check - sicherheitshalber senden */ }\n\n// Erst aus DB suchen\nlet lehrerTelefon = '';\nlet lehrerName = 'Zustaendiger Fahrlehrer';\n\nif (wunschLehrer && fahrlehrerListe.length > 0) {\n  for (const item of fahrlehrerListe) {\n    const fl = item.json;\n    const flName = `${fl.vorname} ${fl.nachname}`.toLowerCase();\n    if (flName.includes(wunschLehrer) || wunschLehrer.includes(fl.nachname.toLowerCase())) {\n      lehrerTelefon = fl.telefon;\n      lehrerName = `${fl.vorname} ${fl.nachname}`;\n      break;\n    }\n  }\n}\n\n// Fallback: FAHRLEHRER_CONFIG env oder default\nif (!lehrerTelefon) {\n  try {\n    const config = JSON.parse($env.FAHRLEHRER_CONFIG || '{}');\n    if (wunschLehrer) {\n      for (const [name, tel] of Object.entries(config)) {\n        if (name === 'default') continue;\n        if (name.toLowerCase() === wunschLehrer || wunschLehrer.includes(name.toLowerCase())) {\n          lehrerTelefon = tel;\n          lehrerName = name;\n          break;\n        }\n      }\n    }\n    if (!lehrerTelefon) lehrerTelefon = config.default || '';\n  } catch(e) {}\n}\n\nif (!lehrerTelefon) {\n  lehrerTelefon = $env.FAHRLEHRER_TELEFON || $env.FAHRSCHULINHABER_TELEFON || '';\n}\n\n// Pass through original buchung fields for downstream nodes\nreturn [{\n  json: {\n    buchungsId: buchung.buchungs_id || buchung.buchungsId,\n    schuelerName: `${buchung.vorname} ${buchung.nachname}`,\n    telefon: buchung.telefon,\n    email: buchung.email,\n    wunschDatum: buchung.wunsch_datum,\n    wunschZeit: buchung.wunsch_zeit,\n    terminArt: buchung.termin_art,\n    fahrlehrerWunsch: buchung.fahrlehrer_wunsch,\n    fuehrerscheinKlasse: buchung.fuehrerschein_klasse,\n    nachricht: buchung.nachricht,\n    lehrerTelefon,\n    lehrerName,\n    schuelerOptOut\n  }\n}];"
      },
      "id": "find-lehrer",
      "name": "Zustaendigen Fahrlehrer finden",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1180, 400]
