        "url": "={{ $env.SUPABASE_URL }}/rest/v1/fahrlehrer?tenant_id=eq.{{ $env.TENANT_ID }}&aktiv=eq.true&select=id,vorname,nachname,telefon",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
