    {
      "parameters": {
        "jsCode": "// Buchungsdaten normalisieren (Website oder WhatsApp)\nconst body = $input.first().json.body || $input.first().json;\n\nlet schuelerName = body.name || body.schuelerName || body.Name || '';\nlet vorname = body.vorname || body.Vorname || '';\nlet nachname = body.nachname || body.Nachname || '';\nlet telefon = body.telefon || body.phone || body.Telefon || '';\nlet email = body.email || body.Email || '';\nlet wunschDatum = body.datum || body.date || body.Datum || '';\nlet wunschZeit = body.zeit || body.time || body.Zeit || body.Uhrzeit || '';\nlet terminArt = body.art || body.type || body.Art || 'Fahrstunde';\nlet fahrlehrerWunsch = body.fahrlehrer || body.instructor || body.Fahrlehrer || '';\nlet nachricht = body.nachricht || body.message || body.Nachricht || '';\nlet fuehrerscheinKlasse = body.klasse || body.Klasse || body.license_class || 'B';\n\n// Name aus vorname+nachname zusammensetzen falls noetig\nif (!schuelerName && vorname && nachname) {\n  schuelerName = `${vorname} ${nachname}`;\n}\nif (schuelerName && !vorname) {\n  const parts = schuelerName.split(' ');\n  vorname = parts[0] || '';\n  nachname = parts.slice(1).join(' ') || '';\n}\n\n// Telefonnummer bereinigen\ntelefon = telefon.toString().replace(/[\\s\\-\\/\\(\\)]/g, '');\nif (telefon && !telefon.startsWith('+')) {\n  telefon = '+49' + telefon.replace(/^0/, '');\n}\n\n// Buchungs-ID generieren\nconst buchungsId = 'BK-' + Date.now().toString(36).toUpperCase();\n\nreturn [{\n  json: {\n    buchungsId,\n    schuelerName,\n    vorname,\n    nachname,\n    telefon,\n    email,\n    wunschDatum,\n    wunschZeit,\n    terminArt,\n    fahrlehrerWunsch,\n    fuehrerscheinKlasse,\n    nachricht,\n    eingang: new Date().toISOString(),\n    status: 'neu'\n  }\n}];"
      },
      "id": "normalize-buchung",
      "name": "Buchung normalisieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 400]
    },
