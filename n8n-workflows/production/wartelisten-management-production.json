        "path": "termin-absage",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-absage-wl",
      "name": "Terminabsage empfangen",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        220,
        300
      ],
      "webhookId": "termin-absage"
    },
    {
      "parameters": {
        "jsCode": "// Absage-Payload normalisieren\nconst body = $input.first().json.body || $input.first().json;\n\nconst datum     = body.datum      || body.Datum      || '';\nconst zeit      = body.zeit       || body.Zeit       || body.Uhrzeit || '';\nconst fahrlehrer = body.fahrlehrer || body.Fahrlehrer || '';\nconst art       = body.art        || body.Art        || 'Fahrstunde';\nconst abgesagtVon  = body.schueler || body.Schueler || body.name || '';\nconst quelle    = body.quelle     || 'manuell';\nlet   abgesagtTelefon = (body.telefon || body.Telefon || '').toString();\n\nabgesagtTelefon = abgesagtTelefon.replace(/[\\s\\-\\/\\(\\)]/g, '');\nif (abgesagtTelefon && !abgesagtTelefon.startsWith('+')) {\n  abgesagtTelefon = '+49' + abgesagtTelefon.replace(/^0/, '');\n}\n\nconst slotId = `${datum}_${zeit.replace(':','')}_ ${fahrlehrer}`.replace(/\\s+/g, '_');\n\nreturn [{ json: { datum, zeit, fahrlehrer, art, abgesagtVon, abgesagtTelefon, slotId, quelle, timestamp: new Date().toISOString() } }];"
      },
      "id": "parse-absage",
      "name": "Absage normalisieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/warteliste?tenant_id=eq.{{ $env.TENANT_ID }}&status=eq.wartend&select=id,vorname,nachname,telefon,wa_opt_out,wunsch_tage,fahrlehrer,prioritaet",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "fullResponse": false
            }
          }
        }
      },
      "id": "load-warteliste",
      "name": "Warteliste laden (Production)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Top-3 passende Schueler von der Warteliste ermitteln\nconst warteliste = $('Warteliste laden (Production)').all();\nconst slot = $('Absage normalisieren').first().json;\n\nconst kandidaten = [];\n\nfor (const item of warteliste) {\n  const d = item.json;\n  if (d.wa_opt_out) continue;\n\n  const name = `${d.vorname} ${d.nachname}`;\n  const telefon = d.telefon || '';\n  if (!name || !telefon) continue;\n\n  const wunschTage   = (d.wunsch_tage   || '').toLowerCase();\n  const wunschLehrer = (d.fahrlehrer    || '').toLowerCase();\n  const prioritaet   = parseInt(d.prioritaet || '5', 10);\n\n  // Score-System: je hoeher, desto bevorzugter\n  let score = 10 - Math.min(prioritaet, 9);\n\n  // Bonus: Wunsch-Fahrlehrer stimmt ueberein\n  if (wunschLehrer && slot.fahrlehrer && slot.fahrlehrer.toLowerCase().includes(wunschLehrer)) score += 5;\n\n  // Bonus: Wunschtag stimmt ueberein\n  if (wunschTage && slot.datum) {\n    const wochentage = ['montag','dienstag','mittwoch','donnerstag','freitag','samstag'];\n    const slotTag = new Date(slot.datum).getDay();\n    const tagName = wochentage[slotTag - 1] || '';\n    if (tagName && wunschTage.includes(tagName)) score += 3;\n  }\n\n  kandidaten.push({ json: { schuelerName: name, schuelerTelefon: telefon, wartelisteId: d.id, score, ...slot } });\n}\n\nkandidaten.sort((a, b) => b.json.score - a.json.score);\nconst top3 = kandidaten.slice(0, 3);\n\nreturn top3.length > 0 ? top3 : [{ json: { skip: true, ...slot } }];"
      },
      "id": "match-warteliste",
      "name": "Top-3 Kandidaten ermitteln",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ]
    },
