        "jsCode": "// JA / NEIN Response des Schuelers verarbeiten\nconst body = $input.first().json.body || $input.first().json;\nconst from = (body.From || body.from || '').replace('whatsapp:', '').trim();\nconst msg  = (body.Body || body.body || '').trim().toUpperCase();\n\nconst hatJa   = msg === 'JA' || msg === 'YES' || msg === 'OK';\nconst hatNein = msg === 'NEIN' || msg === 'NO' || msg === 'NEIN DANKE';\n\nreturn [{ json: { from, msg, hatJa, hatNein } }];"
