    {
      "parameters": {
        "jsCode": "// Abgelaufene Angebote finden (ablauf_um < jetzt)\nconst logItems = $input.all();\nconst now = new Date();\n\nconst slotMap = {};\n\nfor (const item of logItems) {\n  const d = item.json;\n  const details = d.details || {};\n  const ablaufStr = details.ablauf_um || '';\n  if (!ablaufStr) continue;\n\n  let ablauf;\n  try { ablauf = new Date(ablaufStr); } catch(e) { continue; }\n  if (isNaN(ablauf.getTime())) continue;\n\n  const istAbgelaufen = ablauf < now;\n  const slotId = details.slot_id || '';\n\n  if (!slotMap[slotId]) slotMap[slotId] = { items: [], hatAktives: false };\n  slotMap[slotId].items.push({ ...d, istAbgelaufen, details });\n  if (!istAbgelaufen) slotMap[slotId].hatAktives = true;\n}\n\nconst results = [];\nfor (const [slotId, data] of Object.entries(slotMap)) {\n  if (data.hatAktives) continue;\n  const hatAngenommen = data.items.some(i => (i.status || '').toLowerCase() === 'angenommen');\n  if (hatAngenommen) continue;\n\n  const hatAbgelaufen = data.items.some(i => i.istAbgelaufen);\n  if (!hatAbgelaufen) continue;\n\n  const repr = data.items[0];\n\n  results.push({\n    json: {\n      slotId,\n      datum: repr.details.datum,\n      zeit: repr.details.zeit,\n      art: repr.details.art,\n      fahrlehrer: repr.details.fahrlehrer,\n      anzahlKontaktiert: data.items.length,\n      logIds: data.items.map(i => i.id)\n    }\n  });\n}\n\nreturn results.length > 0 ? results : [{ json: { skip: true } }];"
      },
