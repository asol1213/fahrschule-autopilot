    {
      "parameters": {
        "jsCode": "// WhatsApp Follow-Up Nachricht basierend auf Intent generieren\nconst data = $input.first().json;\nlet message = '';\nconst name = data.callerName ? ` ${data.callerName}` : '';\nconst fahrschulName = $env.FAHRSCHUL_NAME || 'Ihre Fahrschule';\nconst websiteUrl = $env.WEBSITE_URL || '';\n\nswitch (data.intent) {\n  case 'anmeldung':\n    message = `Hallo${name}, vielen Dank fuer Ihren Anruf! 🚗\\n\\nSie koennen sich direkt online anmelden --- das dauert nur 3 Minuten:\\n${websiteUrl}/anmeldung\\n\\nBei Fragen sind wir jederzeit erreichbar.\\n\\nIhr Team von ${fahrschulName}`;\n    break;\n  case 'termin':\n    message = `Hallo${name}, danke fuer Ihren Anruf! 📅\\n\\nUnser Buero meldet sich innerhalb von 24 Stunden bei Ihnen, um einen Termin zu vereinbaren.\\n\\nAlternativ: ${websiteUrl}/anmeldung\\n\\nIhr Team von ${fahrschulName}`;\n    break;\n  case 'beschwerde':\n    message = `Hallo${name}, vielen Dank fuer Ihr Feedback.\\n\\nWir nehmen Ihr Anliegen sehr ernst und ein Mitarbeiter wird sich persoenlich bei Ihnen melden.\\n\\nIhr Team von ${fahrschulName}`;\n    break;\n  default:\n    message = `Hallo${name}, vielen Dank fuer Ihren Anruf bei ${fahrschulName}! 🚗\\n\\nFalls Sie weitere Fragen haben, erreichen Sie uns jederzeit telefonisch oder ueber unsere Website:\\n${websiteUrl}\\n\\nIhr Team von ${fahrschulName}`;\n}\n\n// Telefonnummer fuer Twilio formatieren\nlet recipientPhone = (data.callerPhone || '').toString().replace(/[\\s\\-\\/\\(\\)]/g, '');\nif (recipientPhone && !recipientPhone.startsWith('+')) {\n  recipientPhone = '+49' + recipientPhone.replace(/^0/, '');\n}\n\nreturn [{\n  json: {\n    ...data,\n    whatsappMessage: message,\n    recipientPhone\n  }\n}];"
      },
      "id": "generate-followup-msg",
      "name": "Follow-Up Nachricht generieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1360, 700]
    },
