{
  "name": "Fahrschule Autopilot - Empfehlung & Glueckwuensche (Supabase)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 2
            }
