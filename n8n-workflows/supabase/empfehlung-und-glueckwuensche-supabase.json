    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "from": "={{ $env.TWILIO_WHATSAPP_FROM }}",
        "to": "=whatsapp:{{ $json.schuelerTelefon }}",
        "body": "=Hallo {{ $json.schuelerName }}! 📋\n\nErinnerung: Ihre {{ $json.pruefungTyp }} (Klasse {{ $json.klasse }}) ist morgen!\n\n📅 {{ $json.pruefungDatum }}\n\n✅ Checkliste fuer morgen:\n• Personalausweis mitbringen\n• Brille nicht vergessen (falls noetig)\n• Frueh genug da sein (15 Min vorher)\n• Ausreichend geschlafen?\n• Fruehstueck nicht vergessen\n\n💡 Tipp: Gehen Sie heute Abend nochmal die wichtigsten Verkehrszeichen durch und schlafen Sie frueh!\n\nSie schaffen das! 💪🚗\n\nIhre {{ $env.FAHRSCHUL_NAME }}"
      },
