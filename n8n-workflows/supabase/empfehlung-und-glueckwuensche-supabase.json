      "id": "trigger-pruefung",
      "name": "Alle 2 Stunden pruefen",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        220,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/pruefungen?tenant_id=eq.{{ $env.TENANT_ID }}&select=*,schueler:schueler_id(id,vorname,nachname,telefon,wa_opt_out,klasse)",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "fullResponse": false
            }
          }
        }
      },
      "id": "load-pruefungen",
      "name": "Pruefungen laden (Supabase)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        200
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/automation_log?typ=in.(pruefung_bestaetigung,glueckwuensche,empfehlung)&tenant_id=eq.{{ $env.TENANT_ID }}&select=telefon,typ,created_at",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}"
            }
          ]
        },
        "options": {}
      },
      "id": "load-log",
      "name": "Bereits gesendete Nachrichten laden",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        420
      ]
    },
    {
      "parameters": {
        "jsCode": "// Pruefungs-Nachrichten: Bestaetigung, Glueckwuensche, Empfehlung\nconst pruefungen = $('Pruefungen laden (Supabase)').all();\nconst logItems = $('Bereits gesendete Nachrichten laden').all();\n\nconst gesendet = new Set();\nfor (const item of logItems) {\n  const key = `${item.json.telefon}_${item.json.typ}`;\n  gesendet.add(key);\n}\n\nconst now = new Date();\nconst results = [];\n\nfor (const item of pruefungen) {\n  const p = item.json;\n  const schueler = p.schueler;\n  if (!schueler || schueler.wa_opt_out) continue;\n\n  const name = `${schueler.vorname} ${schueler.nachname}`;\n  const telefon = schueler.telefon;\n  const klasse = schueler.klasse || 'B';\n  const pruefungDatum = p.datum || '';\n  const pruefungErgebnis = (p.ergebnis || '').toLowerCase();\n  const pruefungTyp = p.typ || 'Praktische Pruefung';\n\n  if (!telefon || !name) continue;\n\n  // Pruefungstermin-Bestaetigung (1-2 Tage vorher)\n  if (pruefungDatum && pruefungErgebnis !== 'bestanden') {\n    let pruefung;\n    try {\n      pruefung = new Date(pruefungDatum + 'T09:00:00');\n    } catch(e) { continue; }\n\n    if (!isNaN(pruefung.getTime())) {\n      const stundenBis = (pruefung.getTime() - now.getTime()) / (1000 * 60 * 60);\n\n      if (stundenBis >= 20 && stundenBis <= 48) {\n        const key = `${telefon}_pruefung_bestaetigung`;\n        if (!gesendet.has(key)) {\n          results.push({\n            json: {\n              schuelerName: name,\n              schuelerTelefon: telefon,\n              schuelerId: schueler.id,\n              typ: 'pruefung_bestaetigung',\n              pruefungDatum,\n              pruefungTyp,\n              klasse\n            }\n          });\n        }\n      }\n    }\n  }\n\n  // Glueckwuensche + Empfehlung (nach bestandener Pruefung)\n  if (pruefungErgebnis === 'bestanden') {\n    const bestandenDatum = p.bestanden_am || p.datum;\n    let bestanden;\n    try {\n      bestanden = new Date(bestandenDatum);\n    } catch(e) { continue; }\n\n    if (!isNaN(bestanden.getTime())) {\n      const stundenSeit = (now.getTime() - bestanden.getTime()) / (1000 * 60 * 60);\n\n      // Glueckwuensche: 2-8h nach Bestehen\n      if (stundenSeit >= 2 && stundenSeit <= 8) {\n        const key = `${telefon}_glueckwuensche`;\n        if (!gesendet.has(key)) {\n          results.push({\n            json: {\n              schuelerName: name,\n              schuelerTelefon: telefon,\n              schuelerId: schueler.id,\n              typ: 'glueckwuensche',\n              klasse\n            }\n          });\n        }\n      }\n\n      // Empfehlung: 3-7 Tage nach Bestehen\n      if (stundenSeit >= 72 && stundenSeit <= 168) {\n        const key = `${telefon}_empfehlung`;\n        if (!gesendet.has(key)) {\n          results.push({\n            json: {\n              schuelerName: name,\n              schuelerTelefon: telefon,\n              schuelerId: schueler.id,\n              typ: 'empfehlung',\n              klasse\n            }\n          });\n        }\n      }\n    }\n  }\n}\n\nreturn results.length > 0 ? results : [{ json: { skip: true } }];"
      },
      "id": "process-pruefung",
      "name": "Pruefungs-Nachrichten ermitteln",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "filter-skip",
              "leftValue": "={{ $json.skip }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notTrue"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "filter-pruefung",
      "name": "Nur gueltige Nachrichten",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [
        920,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {},
          "conditions": [
            {
              "leftValue": "={{ $json.typ }}",
              "rightValue": "pruefung_bestaetigung",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "fallbackOutput": "extra",
        "options": {},
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.typ }}",
                    "rightValue": "pruefung_bestaetigung",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "outputIndex": 0
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.typ }}",
                    "rightValue": "glueckwuensche",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "outputIndex": 1
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.typ }}",
                    "rightValue": "empfehlung",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "outputIndex": 2
            }
          ]
        }
      },
      "id": "switch-typ",
      "name": "Nachrichtentyp bestimmen",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        1140,
