        "to": "=whatsapp:{{ $env.FAHRSCHULINHABER_TELEFON }}",
        "body": "=⚠️ Mahnung gesendet!\n\n👤 {{ $json.schuelerName }}\n💰 {{ $json.betrag }} EUR\n🔔 {{ $json.stufeText }} (Tag {{ $json.tageUeberfaellig }})\n\n{{ $json.stufe === 'zahlung_stufe3' ? '🔴 LETZTE STUFE! Bitte persoenlich nachfassen.' : '' }}"
      },
      "id": "notify-inhaber",
      "name": "Inhaber informieren",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [
        1620,
        700
      ],
      "credentials": {
        "twilioApi": {
