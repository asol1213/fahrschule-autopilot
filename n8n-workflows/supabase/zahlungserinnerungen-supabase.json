        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"tenant_id\": \"{{ $env.TENANT_ID }}\",\n  \"schueler_id\": \"{{ $json.schuelerId }}\",\n  \"telefon\": \"{{ $json.schuelerTelefon }}\",\n  \"typ\": \"{{ $json.stufe }}\",\n  \"kanal\": \"whatsapp\",\n  \"status\": \"gesendet\",\n  \"details\": { \"betrag\": {{ $json.betrag }}, \"tage_ueberfaellig\": {{ $json.tageUeberfaellig }}, \"zahlung_id\": \"{{ $json.zahlungId }}\" }\n}",
        "options": {}
      },
      "id": "log-supabase",
      "name": "In Supabase loggen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1620,
        300
